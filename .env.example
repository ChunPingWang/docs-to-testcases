# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=docstest
DATABASE_URL=postgresql://appuser:apppass@postgres:5432/docstest

# ── Primary LLM Provider (Gemini — always active) ─────
LLM_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# ── Optional: Ollama (local, set OLLAMA_ENABLED=true) ─
OLLAMA_ENABLED=false
OLLAMA_API_BASE_URL=http://ollama:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_LLM_MODEL=llama3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Optimization modes: rag | rag_finetune | rag_fewshot | prompt_only
OLLAMA_OPTIMIZATION_MODE=rag_finetune

# ── Optional: OpenAI (set OPENAI_ENABLED=true) ────────
OPENAI_ENABLED=false
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_OPTIMIZATION_MODE=rag

# ── ChromaDB ───────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── AI Service ─────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000

# ── Paths (Docker volumes) ────────────────────────────
UPLOAD_DIR=/data/uploads
FEATURES_DIR=/data/features
GENERATED_TESTS_DIR=/data/generated-tests
FINETUNE_DIR=/data/finetune

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
