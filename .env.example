# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=docstest
DATABASE_URL=postgresql://appuser:apppass@postgres:5432/docstest

# ── LLM API (OpenAI-compatible) ─────────────────────────
LLM_API_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=MiniMax-M2.5
EMBEDDING_MODEL=embo-01

# ── ChromaDB ───────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── AI Service ─────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000

# ── Paths (Docker volumes) ────────────────────────────
UPLOAD_DIR=/data/uploads
FEATURES_DIR=/data/features
GENERATED_TESTS_DIR=/data/generated-tests
FINETUNE_DIR=/data/finetune

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
